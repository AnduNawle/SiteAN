rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        (request.auth.token.email == "youknowfeus@gmail.com")
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
             data.status in ['draft', 'published'] &&
             (data.image == null || (data.image is string && data.image.size() <= 1000));
    }

    function isValidJoinRequest(data) {
      return data.firstname is string && data.firstname.size() > 0 && data.firstname.size() <= 100 &&
             data.lastname is string && data.lastname.size() > 0 && data.lastname.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.engagementType in ['sympathisant', 'membre', 'benevole', 'responsable_local'] &&
             data.createdAt == request.time &&
             (data.phone == null || (data.phone is string && data.phone.size() <= 30)) &&
             (data.locality == null || (data.locality is string && data.locality.size() <= 200)) &&
             (data.profession == null || (data.profession is string && data.profession.size() <= 200)) &&
             (data.message == null || (data.message is string && data.message.size() <= 5000));
    }

    function isValidContactMessage(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 300 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() && isValidId(userId);
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(articleId) && isValidArticle(incoming());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(categoryId);
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(eventId);
    }

    match /programs/{programId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(programId);
    }

    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(memberId);
    }

    match /join_requests/{requestId} {
      allow create: if isValidJoinRequest(incoming()) && isValidId(requestId);
      allow read, update, delete: if isAdmin() && isValidId(requestId);
    }

    match /contact_messages/{messageId} {
      allow create: if isValidContactMessage(incoming()) && isValidId(messageId);
      allow read, update, delete: if isAdmin() && isValidId(messageId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }
  }
}
